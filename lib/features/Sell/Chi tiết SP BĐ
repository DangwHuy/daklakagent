  late final Animation<double> _buyBtnScale;

  // ── Countdown timer ──
  Timer? _countdownTimer;
  int _remainSeconds = 2 * 3600 + 45 * 60 + 18; // 02:45:18

  final List<String> _typeNames = ['Cán gỗ', 'Cán inox', 'Cán nhựa'];
